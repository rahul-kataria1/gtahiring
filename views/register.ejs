<%- include('partials/header') %>
  <style>
    .auth-wrap { max-width: 460px; margin: 24px auto 0; }
    .auth-card {
      background: var(--card); border: 1px solid var(--border); border-radius: 20px;
      padding: 36px 40px; box-shadow: 0 8px 40px rgba(0,87,216,0.1); margin-top: 8px;
    }
    .auth-icon {
      width: 52px; height: 52px; border-radius: 14px; margin: 0 auto 16px;
      background: linear-gradient(135deg, var(--violet) 0%, var(--violet-deeper) 100%);
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 6px 18px rgba(0,87,216,0.28);
    }
    .auth-icon svg { width: 24px; height: 24px; color: #fff; }
    .auth-card h1 { text-align: center; margin-bottom: 4px; }
    .auth-card .subtitle { text-align: center; margin-bottom: 24px; }

    .field-icon-wrap { position: relative; }
    .field-icon-wrap svg.field-icon {
      position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
      width: 17px; height: 17px; color: var(--muted); pointer-events: none;
    }
    .field-icon-wrap input { padding-left: 42px !important; }
    .field-icon-wrap .pw-toggle {
      position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
      background: none; border: none; cursor: pointer; color: var(--muted);
      padding: 4px; display: flex; align-items: center;
    }
    .field-icon-wrap .pw-toggle:hover { color: var(--violet-dark); }
    .field-icon-wrap .pw-toggle svg { width: 17px; height: 17px; }
    .field-icon-wrap input[type="password"],
    .field-icon-wrap input[type="text"].pw-field { padding-right: 42px !important; }

    /* Role picker */
    .role-picker { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 18px; }
    .role-option { position: relative; }
    .role-option input { position: absolute; opacity: 0; inset: 0; cursor: pointer; margin: 0; }
    .role-option-card {
      border: 1.5px solid var(--border); border-radius: 14px; padding: 16px 14px;
      text-align: center; transition: border-color 0.15s, background 0.15s, box-shadow 0.15s;
      cursor: pointer;
    }
    .role-option-card svg { width: 22px; height: 22px; color: var(--violet); margin-bottom: 8px; }
    .role-option-card strong { display: block; font-size: 0.9rem; }
    .role-option-card span { display: block; font-size: 0.76rem; color: var(--muted); margin-top: 2px; }
    .role-option input:checked + .role-option-card {
      border-color: var(--violet); background: var(--violet-bg);
      box-shadow: 0 0 0 3px rgba(0,87,216,0.12);
    }
    .role-option input:focus-visible + .role-option-card { outline: 2px solid var(--violet); outline-offset: 2px; }

    #companyField { overflow: hidden; max-height: 0; opacity: 0; transition: max-height 0.25s ease, opacity 0.2s ease; }
    #companyField.show { max-height: 110px; opacity: 1; }

    .auth-card .btn { width: 100%; justify-content: center; padding: 12px; font-size: 0.95rem; margin-top: 6px; }
    .auth-footer { text-align: center; margin-top: 18px; color: var(--muted); font-size: 0.88rem; }
  </style>

  <div class="auth-wrap">
    <div class="auth-card">
      <div class="auth-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="17" y1="11" x2="23" y2="11"/></svg>
      </div>
      <h1>Create your account</h1>
      <p class="subtitle">Find your next role or your next hire.</p>

      <% if (error) { %><div class="alert error"><%= error %></div><% } %>

      <form method="POST" action="/register" id="registerForm">
        <div class="role-picker">
          <label class="role-option">
            <input type="radio" name="role" value="seeker" <%= form.role !== 'employer' ? 'checked' : '' %>>
            <div class="role-option-card">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg>
              <strong>Job seeker</strong>
              <span>Find &amp; apply to jobs</span>
            </div>
          </label>
          <label class="role-option">
            <input type="radio" name="role" value="employer" <%= form.role === 'employer' ? 'checked' : '' %>>
            <div class="role-option-card">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
              <strong>Employer</strong>
              <span>Post &amp; manage jobs</span>
            </div>
          </label>
        </div>

        <div class="field">
          <label for="name">Full name</label>
          <div class="field-icon-wrap">
            <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <input type="text" id="name" name="name" value="<%= form.name || '' %>" required placeholder="Jane Smith" autocomplete="name">
          </div>
        </div>

        <div class="field" id="companyField">
          <label for="company_name">Company name</label>
          <div class="field-icon-wrap">
            <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
            <input type="text" id="company_name" name="company_name" value="<%= form.company_name || '' %>" placeholder="Acme Inc." autocomplete="organization">
          </div>
        </div>

        <div class="field">
          <label for="email">Email</label>
          <div class="field-icon-wrap">
            <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 6 12 13 2 6"/><path d="M2 6h20v12H2z"/></svg>
            <input type="email" id="email" name="email" value="<%= form.email || '' %>" required placeholder="you@example.com" autocomplete="email">
          </div>
        </div>

        <div class="field">
          <label for="password">Password</label>
          <div class="field-icon-wrap">
            <svg class="field-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
            <input type="password" id="password" name="password" required minlength="6" placeholder="At least 6 characters" autocomplete="new-password">
            <button type="button" class="pw-toggle" data-target="password" aria-label="Show password">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <button class="btn" type="submit">Create account</button>
      </form>
    </div>
    <p class="auth-footer">Already have an account? <a href="/login">Log in</a></p>
  </div>

  <script>
    document.querySelectorAll('.pw-toggle').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var input = document.getElementById(btn.dataset.target);
        var showing = input.type === 'text';
        input.type = showing ? 'password' : 'text';
        input.classList.toggle('pw-field', !showing);
        btn.setAttribute('aria-label', showing ? 'Show password' : 'Hide password');
      });
    });

    var companyField = document.getElementById('companyField');
    function syncCompanyField() {
      var role = document.querySelector('input[name="role"]:checked').value;
      companyField.classList.toggle('show', role === 'employer');
    }
    document.querySelectorAll('input[name="role"]').forEach(function (r) {
      r.addEventListener('change', syncCompanyField);
    });
    syncCompanyField();
  </script>
<%- include('partials/footer') %>
