<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> · GTA Hiring Admin</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=<%= locals.assetVersion || 0 %>">
</head>
<body class="admin-layout">

  <!-- Sidebar -->
  <aside class="admin-sidebar" id="adminSidebar">
    <div class="admin-sidebar-brand">
      <a href="/admin/dashboard" style="display:flex;align-items:center;gap:10px;text-decoration:none;">
        <img src="/images/logo.png" alt="GTA Hiring" style="height:32px;width:auto;">
        <div class="admin-sidebar-brand-text">
          GTA Hiring
          <span>Admin panel</span>
        </div>
      </a>
    </div>

    <nav class="admin-nav">
      <div class="admin-nav-section">Main</div>

      <a href="/admin/dashboard" class="admin-nav-item" data-path="/admin/dashboard">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Overview
      </a>

      <a href="/admin/jobs" class="admin-nav-item" data-path="/admin/jobs">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
        Jobs
      </a>

      <a href="/admin/users" class="admin-nav-item" data-path="/admin/users">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        Users
      </a>

      <div class="admin-nav-sub">
        <a href="/admin/users?role=seeker" class="admin-nav-sub-item" data-role="seeker">Job seekers</a>
        <a href="/admin/users?role=employer" class="admin-nav-sub-item" data-role="employer">Employers</a>
      </div>

      <div class="admin-nav-section">Content</div>

      <a href="/admin/blog" class="admin-nav-item" data-path="/admin/blog">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        Blog
      </a>

      <a href="/admin/pages" class="admin-nav-item" data-path="/admin/pages">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        Pages
      </a>

      <a href="/admin/messages" class="admin-nav-item" data-path="/admin/messages">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Messages
        <% if (locals.unreadMessageCount) { %><span class="admin-nav-count"><%= unreadMessageCount %></span><% } %>
      </a>

      <a href="/admin/push" class="admin-nav-item" data-path="/admin/push">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
        Push notifications
      </a>

      <a href="/admin/reports" class="admin-nav-item" data-path="/admin/reports">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
        Reports &amp; suggestions
        <% if (locals.unreadReportsCount) { %><span class="admin-nav-count"><%= unreadReportsCount %></span><% } %>
      </a>

      <div class="admin-nav-section">System</div>

      <a href="/profile" class="admin-nav-item" data-path="/profile">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Profile
      </a>

      <a href="/admin/settings" class="admin-nav-item" data-path="/admin/settings">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        Settings
      </a>
    </nav>
  </aside>

  <!-- Mobile overlay -->
  <div class="admin-sidebar-overlay" id="sidebarOverlay"></div>

  <!-- Top bar -->
  <div class="admin-topbar">
    <div style="display:flex;align-items:center;gap:12px;">
      <button class="admin-topbar-hamburger" id="sidebarToggle" aria-label="Toggle menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <span class="admin-topbar-title"><%= title %></span>
    </div>

    <div class="admin-topbar-right">
      <% if (currentUser) { %>
        <%- include('notification-bell') %>
        <%
          var _initials = (currentUser.name || '?').split(' ').map(w => w[0]).slice(0,2).join('').toUpperCase();
        %>
        <a href="/profile" class="admin-topbar-profile" style="text-decoration:none;color:inherit;">
          <div class="admin-topbar-avatar">
            <% if (currentUser.avatar) { %>
              <img src="/uploads/avatars/<%= currentUser.avatar %>" alt="">
            <% } else { %>
              <%= _initials %>
            <% } %>
          </div>
          <%= currentUser.name %>
        </a>
        <div class="admin-topbar-divider"></div>
        <form method="POST" action="/logout">
          <button type="submit" class="admin-logout-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Log out
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- Main content -->
  <div class="admin-main">
    <div class="admin-main-inner">
