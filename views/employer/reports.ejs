<%- include('../partials/employer-header') %>
  <style>
    .report-new-card {
      background: #fff; border: 1px solid var(--border); border-radius: 16px;
      padding: 20px 22px; margin-bottom: 24px;
    }
    .report-new-card h2 { font-size: 1rem; margin: 0 0 14px; }

    .report-card {
      background: #fff; border: 1px solid var(--border); border-radius: 14px;
      margin-bottom: 16px; overflow: hidden;
    }
    .report-card.unread { border-left: 4px solid var(--violet); }
    .report-card-head {
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      padding: 14px 20px; border-bottom: 1px solid var(--border-light);
      background: var(--violet-bg);
    }
    .report-card-title { display: flex; align-items: center; gap: 10px; }
    .report-type-pill {
      font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em;
      padding: 3px 10px; border-radius: 20px;
    }
    .report-type-pill.report { background: var(--danger-bg); color: var(--danger-dark); }
    .report-type-pill.suggestion { background: var(--success-bg); color: var(--success-text); }
    .report-card-subject { font-weight: 700; font-size: 0.92rem; color: var(--text); }
    .report-status-pill {
      font-size: 0.72rem; font-weight: 700; padding: 3px 10px; border-radius: 20px;
    }
    .report-status-pill.open { background: #d1fae5; color: #065f46; }
    .report-status-pill.closed { background: #e5e7eb; color: #4b5563; }

    .report-thread { padding: 16px 20px; display: flex; flex-direction: column; gap: 12px; }
    .report-msg { max-width: 85%; padding: 10px 14px; border-radius: 12px; font-size: 0.87rem; line-height: 1.5; }
    .report-msg.employer { align-self: flex-end; background: var(--violet); color: #fff; border-bottom-right-radius: 4px; }
    .report-msg.admin { align-self: flex-start; background: var(--border-light); color: var(--text); border-bottom-left-radius: 4px; }
    .report-msg-meta { font-size: 0.7rem; opacity: 0.75; margin-top: 4px; }

    .report-reply-form { padding: 0 20px 18px; display: flex; gap: 8px; }
    .report-reply-form textarea { flex: 1; resize: vertical; min-height: 44px; }
  </style>

  <h1>Reports &amp; suggestions</h1>
  <p class="subtitle">Send feedback or report an issue directly to the GTA Hiring team.</p>

  <div class="report-new-card">
    <h2>New report or suggestion</h2>
    <% if (error) { %><div class="alert error" style="margin-bottom:14px;"><%= error %></div><% } %>
    <form method="POST" action="/employer/reports">
      <div style="display:grid;grid-template-columns:160px 1fr;gap:16px;">
        <div class="field">
          <label for="type">Type</label>
          <select id="type" name="type">
            <option value="suggestion">Suggestion</option>
            <option value="report">Report a problem</option>
          </select>
        </div>
        <div class="field">
          <label for="subject">Subject</label>
          <input id="subject" name="subject" type="text" placeholder="Short summary" required>
        </div>
      </div>
      <div class="field">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="3" placeholder="Tell us what's going on…" required style="resize:vertical;"></textarea>
      </div>
      <button class="btn" type="submit">Submit →</button>
    </form>
  </div>

  <% if (reports.length === 0) { %>
    <div class="empty-state"><p>You haven't submitted any reports or suggestions yet.</p></div>
  <% } else { %>
    <% reports.forEach(r => { %>
      <div class="report-card <%= r.employer_unread ? 'unread' : '' %>">
        <div class="report-card-head">
          <div class="report-card-title">
            <span class="report-type-pill <%= r.type %>"><%= r.type %></span>
            <span class="report-card-subject"><%= r.subject %></span>
          </div>
          <span class="report-status-pill <%= r.status %>"><%= r.status %></span>
        </div>
        <div class="report-thread">
          <% r.messages.forEach(m => { %>
            <div class="report-msg <%= m.sender_role %>">
              <%= m.message %>
              <div class="report-msg-meta"><%= m.sender_role === 'admin' ? 'GTA Hiring team' : 'You' %> &middot; <%= m.created_at.slice(0, 16).replace('T', ' ') %></div>
            </div>
          <% }) %>
        </div>
        <form class="report-reply-form" method="POST" action="/employer/reports/<%= r.id %>/reply">
          <textarea name="message" placeholder="Reply…" required></textarea>
          <button class="btn small" type="submit">Send</button>
        </form>
      </div>
    <% }) %>
  <% } %>
<%- include('../partials/employer-footer') %>
