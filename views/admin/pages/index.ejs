<%- include('../../partials/admin-header') %>
  <style>
    .pages-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
      margin-top: 28px;
    }
    .page-card {
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: 18px;
      overflow: hidden;
      transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
    }
    .page-card:hover {
      box-shadow: 0 8px 30px rgba(0,87,216,0.12);
      border-color: var(--violet-light);
      transform: translateY(-2px);
    }
    .page-card-head {
      background: linear-gradient(135deg, #001f5b 0%, #0057d8 60%, #4a9af5 100%);
      padding: 20px 22px 16px;
      position: relative; overflow: hidden;
    }
    .page-card-head::before {
      content: ''; position: absolute; right: -30px; top: -30px;
      width: 120px; height: 120px;
      background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 65%);
      pointer-events: none;
    }
    .page-card-icon {
      width: 38px; height: 38px; border-radius: 10px;
      background: rgba(255,255,255,0.18);
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 10px; position: relative; z-index: 1;
    }
    .page-card-icon svg { width: 18px; height: 18px; color: #fff; }
    .page-card-head h2 { color: #fff; font-size: 1rem; margin: 0 0 2px; position: relative; z-index: 1; }
    .page-card-head p  { color: rgba(255,255,255,0.65); font-size: 0.78rem; margin: 0; position: relative; z-index: 1; }
    .page-card-body { padding: 16px 22px 20px; }
    .page-card-meta {
      display: flex; align-items: center; gap: 6px;
      font-size: 0.78rem; color: var(--muted); margin-bottom: 16px;
    }
    .page-card-meta svg { width: 12px; height: 12px; }
    .page-url {
      display: inline-flex; align-items: center; gap: 5px;
      background: var(--violet-bg); color: var(--violet-dark);
      border: 1px solid var(--violet-light); border-radius: 6px;
      font-size: 0.75rem; font-weight: 600; padding: 3px 9px;
      margin-bottom: 16px; text-decoration: none;
      transition: background 0.15s;
    }
    .page-url:hover { background: var(--violet-bg2); text-decoration: none; }
    .page-url svg { width: 11px; height: 11px; }
    .page-card-actions { display: flex; gap: 8px; }
    .btn-edit-page {
      flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 6px;
      background: var(--violet); color: #fff; border: none;
      border-radius: 10px; padding: 9px 16px; font-size: 0.84rem; font-weight: 700;
      text-decoration: none; transition: background 0.15s, box-shadow 0.15s;
      box-shadow: 0 2px 8px rgba(0,87,216,0.28);
    }
    .btn-edit-page:hover { background: var(--violet-dark); box-shadow: 0 4px 14px rgba(0,87,216,0.4); text-decoration: none; color: #fff; }
    .btn-edit-page svg { width: 13px; height: 13px; }
    .btn-preview-page {
      display: inline-flex; align-items: center; justify-content: center;
      width: 38px; height: 38px; border-radius: 10px;
      border: 1.5px solid var(--border); background: #fff;
      color: var(--muted); text-decoration: none;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .btn-preview-page:hover { border-color: var(--violet-light); color: var(--violet); background: var(--violet-bg); text-decoration: none; }
    .btn-preview-page svg { width: 15px; height: 15px; }
  </style>

  <h1>Pages</h1>
  <p class="subtitle">Edit the content of public pages displayed site-wide.</p>

  <div class="pages-grid">
    <%
      const pagesMeta = {
        privacy: {
          icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
          desc: 'Data collection, usage, and user rights information.',
          url: '/privacy'
        },
        terms: {
          icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
          desc: 'Rules and responsibilities for all users of the platform.',
          url: '/terms'
        },
        contact: {
          icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
          desc: 'Contact details and the public-facing contact form page.',
          url: '/contact'
        }
      };
    %>
    <% pages.forEach(p => {
      const pm = pagesMeta[p.slug] || {};
      const updated = new Date(p.updated_at).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' });
    %>
      <div class="page-card">
        <div class="page-card-head">
          <div class="page-card-icon"><%- pm.icon %></div>
          <h2><%= p.title %></h2>
          <p><%= pm.desc %></p>
        </div>
        <div class="page-card-body">
          <a class="page-url" href="<%= pm.url %>" target="_blank">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            <%= pm.url %>
          </a>
          <div class="page-card-meta">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
            Last updated <%= updated %>
          </div>
          <div class="page-card-actions">
            <a class="btn-edit-page" href="/admin/pages/<%= p.slug %>/edit">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              Edit page
            </a>
            <a class="btn-preview-page" href="<%= pm.url %>" target="_blank" title="Preview">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<%- include('../../partials/admin-footer') %>
