<%- include('../partials/admin-header') %>
  <style>
    .msg-card {
      background: #fff; border: 1px solid var(--border); border-radius: 14px;
      padding: 18px 22px; margin-bottom: 14px;
    }
    .msg-card.unread { border-left: 4px solid var(--violet); }
    .msg-card-head {
      display: flex; align-items: flex-start; justify-content: space-between;
      gap: 16px; margin-bottom: 10px;
    }
    .msg-from strong { display: block; font-size: 0.95rem; color: var(--text); }
    .msg-from span { font-size: 0.82rem; color: var(--muted); }
    .msg-meta { text-align: right; flex-shrink: 0; }
    .msg-date { font-size: 0.78rem; color: var(--muted); }
    .msg-subject {
      display: inline-block; margin-top: 4px; font-size: 0.76rem; font-weight: 700;
      color: var(--violet-dark); background: var(--violet-bg); padding: 3px 10px; border-radius: 20px;
    }
    .msg-body { font-size: 0.89rem; color: var(--text); line-height: 1.6; white-space: pre-wrap; margin-bottom: 12px; }
    .msg-actions { display: flex; gap: 8px; }
  </style>

  <h1>Contact messages</h1>
  <p class="subtitle">
    <%= messages.length %> message<%= messages.length === 1 ? '' : 's' %>
    <% if (unreadCount > 0) { %> &middot; <strong><%= unreadCount %> unread</strong><% } %>
  </p>

  <form class="search-bar" method="GET" action="/admin/messages">
    <% if (status !== 'all') { %><input type="hidden" name="status" value="<%= status %>"><% } %>
    <% if (subject) { %><input type="hidden" name="subject" value="<%= subject %>"><% } %>
    <input type="text" name="q" placeholder="Search by name, email, subject, or message…" value="<%= q %>" autofocus>
    <select name="subject" onchange="this.form.submit()" style="max-width:220px;">
      <option value="">All subjects</option>
      <% subjects.forEach(s => { %>
        <option value="<%= s %>" <%= subject === s ? 'selected' : '' %>><%= s %></option>
      <% }) %>
    </select>
    <button class="btn" type="submit">Search</button>
    <% if (q || subject) { %>
      <a class="btn outline" href="/admin/messages<%= status !== 'all' ? '?status=' + status : '' %>">Clear</a>
    <% } %>
  </form>

  <%
    var baseParts = [];
    if (q) baseParts.push('q=' + encodeURIComponent(q));
    if (subject) baseParts.push('subject=' + encodeURIComponent(subject));
    var baseQS = baseParts.join('&');
    function statusHref(s) {
      var parts = baseParts.slice();
      if (s !== 'all') parts.push('status=' + s);
      return '/admin/messages' + (parts.length ? '?' + parts.join('&') : '');
    }
  %>
  <div class="filter-tabs">
    <a href="<%= statusHref('all') %>" class="<%= status === 'all' ? 'active' : '' %>">All</a>
    <a href="<%= statusHref('unread') %>" class="<%= status === 'unread' ? 'active' : '' %>">Unread</a>
    <a href="<%= statusHref('read') %>" class="<%= status === 'read' ? 'active' : '' %>">Read</a>
  </div>

  <% if (messages.length === 0) { %>
    <div class="empty-state">
      <% if (q || subject || status !== 'all') { %>
        <p>No messages match your filters.</p>
      <% } else { %>
        <p>No messages submitted yet.</p>
      <% } %>
    </div>
  <% } else { %>
    <% messages.forEach(m => { %>
      <div class="msg-card <%= m.read ? '' : 'unread' %>">
        <div class="msg-card-head">
          <div class="msg-from">
            <strong><%= m.name %></strong>
            <span><a href="mailto:<%= m.email %>"><%= m.email %></a></span>
          </div>
          <div class="msg-meta">
            <div class="msg-date"><%= m.created_at.slice(0, 16).replace('T', ' ') %></div>
            <span class="msg-subject"><%= m.subject %></span>
          </div>
        </div>
        <div class="msg-body"><%= m.message %></div>
        <div class="msg-actions">
          <% if (!m.read) { %>
            <form class="inline-form" method="POST" action="/admin/messages/<%= m.id %>/read">
              <input type="hidden" name="_q" value="<%= q %>">
              <input type="hidden" name="_status" value="<%= status %>">
              <input type="hidden" name="_subject" value="<%= subject %>">
              <button class="btn small outline" type="submit">Mark as read</button>
            </form>
          <% } %>
          <form class="inline-form" method="POST" action="/admin/messages/<%= m.id %>/delete"
                onsubmit="return confirm('Delete this message permanently?');">
            <input type="hidden" name="_q" value="<%= q %>">
            <input type="hidden" name="_status" value="<%= status %>">
            <input type="hidden" name="_subject" value="<%= subject %>">
            <button class="btn small danger" type="submit">Delete</button>
          </form>
        </div>
      </div>
    <% }) %>
  <% } %>
<%- include('../partials/admin-footer') %>
