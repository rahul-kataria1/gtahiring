<%- include('../partials/header') %>
  <style>
    /* ── Hero ───────────────────────────────────────────────── */
    .jobs-hero {
      background: linear-gradient(135deg, #001f5b 0%, #0057d8 55%, #4a9af5 100%);
      border-radius: 24px;
      padding: 52px 44px 46px;
      margin-top: 16px;
      margin-bottom: 40px;
      color: #fff;
      position: relative;
      overflow: hidden;
    }
    .jobs-hero::before {
      content: '';
      position: absolute;
      right: -80px; top: -80px;
      width: 380px; height: 380px;
      background: radial-gradient(circle, rgba(255,255,255,0.07) 0%, transparent 65%);
      pointer-events: none;
    }
    .jobs-hero::after {
      content: '';
      position: absolute;
      left: -40px; bottom: -60px;
      width: 260px; height: 260px;
      background: radial-gradient(circle, rgba(0,87,216,0.4) 0%, transparent 70%);
      pointer-events: none;
    }
    .jobs-hero h1 { color: #fff; font-size: 2.3rem; margin-bottom: 8px; position: relative; z-index: 1; }
    .jobs-hero .subtitle { color: rgba(255,255,255,0.7); margin-bottom: 32px; font-size: 1.05rem; position: relative; z-index: 1; }

    .search-row {
      display: grid;
      grid-template-columns: 1fr 1fr auto;
      gap: 10px;
      position: relative;
      z-index: 1;
    }
    @media (max-width: 620px) { .search-row { grid-template-columns: 1fr; } }

    .search-input-wrap { position: relative; }
    .search-input-wrap svg {
      position: absolute; left: 14px; top: 50%;
      transform: translateY(-50%);
      color: rgba(255,255,255,0.55); pointer-events: none;
    }
    .search-row input {
      background: rgba(255,255,255,0.13);
      border: 1.5px solid rgba(255,255,255,0.28);
      color: #fff;
      border-radius: 12px;
      padding: 13px 18px 13px 42px;
      font-size: 0.93rem;
      font-family: inherit;
      width: 100%;
      transition: background 0.18s, border-color 0.18s;
    }
    .search-row input::placeholder { color: rgba(255,255,255,0.48); }
    .search-row input:focus {
      outline: none;
      background: rgba(255,255,255,0.22);
      border-color: rgba(255,255,255,0.7);
      box-shadow: 0 0 0 3px rgba(255,255,255,0.12);
    }
    .btn-search {
      display: inline-flex; align-items: center; gap: 8px;
      background: #fff;
      color: var(--violet-dark);
      border: none;
      border-radius: 12px;
      padding: 13px 28px;
      font-size: 0.93rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 3px 14px rgba(0,0,0,0.22);
      transition: background 0.18s, box-shadow 0.18s, transform 0.12s;
      white-space: nowrap;
      font-family: inherit;
      letter-spacing: -0.01em;
    }
    .btn-search svg { width: 15px; height: 15px; color: var(--violet); }
    .btn-search:hover {
      background: #e8f2ff;
      box-shadow: 0 6px 22px rgba(0,0,0,0.28);
      transform: translateY(-1px);
    }

    /* ── Results bar ─────────────────────────────────────────── */
    .results-bar {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 20px; gap: 10px; flex-wrap: wrap;
    }
    .results-label { font-size: 0.87rem; color: var(--muted); }
    .results-label strong { color: var(--text); font-weight: 700; }
    .results-clear {
      display: inline-flex; align-items: center; gap: 5px;
      font-size: 0.82rem; font-weight: 600; color: var(--violet);
      text-decoration: none; padding: 4px 12px;
      border: 1.5px solid var(--violet-light); border-radius: 20px;
      transition: background 0.15s, color 0.15s;
    }
    .results-clear:hover { background: var(--violet-bg); text-decoration: none; }

    /* ── Job card ────────────────────────────────────────────── */
    .job-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 18px;
      margin-bottom: 14px;
      overflow: hidden;
      transition: box-shadow 0.22s, transform 0.22s, border-color 0.22s;
      position: relative;
    }
    .job-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 4px;
      background: var(--violet-light);
      border-radius: 18px 0 0 18px;
      transition: background 0.22s;
    }
    .job-card:hover {
      box-shadow: 0 8px 36px rgba(0,87,216,0.14);
      transform: translateY(-3px);
      border-color: var(--violet-light);
    }
    .job-card:hover::before { background: var(--violet); }

    .job-card-inner { padding: 22px 24px 22px 28px; }

    /* ── Top row: logo + company + date ─────────────────────── */
    .job-card-top {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      margin-bottom: 14px;
    }
    .job-logo {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.1rem;
      font-weight: 900;
      color: #fff;
      flex-shrink: 0;
      letter-spacing: -0.04em;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }
    .job-logo-img {
      width: 48px; height: 48px;
      border-radius: 12px;
      object-fit: cover; flex-shrink: 0;
      border: 1.5px solid var(--border);
      background: #fff;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    /* 8 colour pairs — picked by first char code */
    .logo-c0 { background: linear-gradient(135deg, #6c5ce7, #a29bfe); }
    .logo-c1 { background: linear-gradient(135deg, #00b894, #00cec9); }
    .logo-c2 { background: linear-gradient(135deg, #e17055, #fab1a0); }
    .logo-c3 { background: linear-gradient(135deg, #0984e3, #74b9ff); }
    .logo-c4 { background: linear-gradient(135deg, #6d4c41, #a1887f); }
    .logo-c5 { background: linear-gradient(135deg, #e84393, #fd79a8); }
    .logo-c6 { background: linear-gradient(135deg, #00b4d8, #90e0ef); }
    .logo-c7 { background: linear-gradient(135deg, #f9a825, #ffe082); }

    .job-card-meta {
      flex: 1;
      min-width: 0;
    }
    .job-company-name {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--muted);
      margin-top: 3px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .job-card-title {
      font-size: 1.08rem;
      font-weight: 700;
      margin: 0;
      line-height: 1.35;
      color: var(--text);
    }
    .job-card-title a { color: inherit; }
    .job-card-title a:hover { color: var(--violet); text-decoration: none; }

    .job-card-date-wrap {
      text-align: right;
      flex-shrink: 0;
    }
    .job-card-date {
      font-size: 0.76rem;
      color: var(--muted);
      white-space: nowrap;
    }
    .new-badge {
      display: inline-block;
      background: linear-gradient(90deg, #00b894, #00cec9);
      color: #fff;
      font-size: 0.64rem;
      font-weight: 800;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 3px 9px;
      border-radius: 20px;
      margin-top: 5px;
    }
    .featured-badge {
      display: inline-block;
      background: linear-gradient(90deg, #fdcb6e, #f39c12);
      color: #7a4a00;
      font-size: 0.64rem;
      font-weight: 800;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 3px 9px;
      border-radius: 20px;
      margin-top: 5px;
    }
    .job-card.is-featured { border-color: #f5c451; background: linear-gradient(135deg, #fffdf6 0%, #fff 60%); }
    .job-card.is-featured::before { background: linear-gradient(180deg, #fdcb6e, #f39c12); }
    .job-card.is-featured:hover::before { background: linear-gradient(180deg, #fdcb6e, #f39c12); }

    /* ── Pills ───────────────────────────────────────────────── */
    .job-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 14px;
    }
    .job-pill {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 11px;
      border-radius: 20px;
      font-size: 0.77rem;
      font-weight: 600;
      white-space: nowrap;
      border: 1px solid transparent;
    }
    .pill-location { background: #e8f4ff; color: #1565c0; border-color: #c5dcf8; }
    .pill-type     { background: #e8faf4; color: #0a7a55; border-color: #b2e8d4; }
    .pill-salary   { background: #fff8e1; color: #8a5c00; border-color: #fde68a; }
    .pill-remote   { background: #f3e8ff; color: #6b21a8; border-color: #dbb6fc; }

    /* ── Excerpt ─────────────────────────────────────────────── */
    .job-excerpt {
      font-size: 0.86rem;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ── Card footer ─────────────────────────────────────────── */
    .job-card-footer {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding: 14px 24px 14px 28px;
      border-top: 1px solid var(--border-light);
      background: #fcfbff;
    }
    .btn-view {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--violet);
      color: #fff;
      border-radius: 10px;
      padding: 9px 20px;
      font-size: 0.84rem;
      font-weight: 700;
      text-decoration: none;
      transition: background 0.18s, box-shadow 0.18s, transform 0.12s;
      box-shadow: 0 2px 8px rgba(0,87,216,0.32);
      letter-spacing: -0.01em;
    }
    .btn-view:hover {
      background: var(--violet-dark);
      box-shadow: 0 4px 16px rgba(0,87,216,0.45);
      transform: translateY(-1px);
      text-decoration: none;
      color: #fff;
    }
    .btn-view svg {
      width: 14px; height: 14px;
      transition: transform 0.18s;
    }
    .btn-view:hover svg { transform: translateX(3px); }

    @media (max-width: 480px) {
      .job-card-top { flex-wrap: wrap; gap: 10px; }
      .job-card-date-wrap { order: -1; width: 100%; text-align: left; display: flex; align-items: center; gap: 8px; }
    }
  </style>

  <!-- Hero -->
  <div class="jobs-hero">
    <h1>Find your next job</h1>
    <p class="subtitle">Browse open roles posted by top employers across the GTA.</p>
    <form class="search-row" method="GET" action="/">
      <div class="search-input-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" name="q" placeholder="Job title, keyword, or company" value="<%= q %>">
      </div>
      <div class="search-input-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
        <input type="text" name="location" placeholder="City or remote" value="<%= location %>">
      </div>
      <button class="btn-search" type="submit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        Search
      </button>
    </form>
  </div>

  <% if (jobs.length === 0) { %>
    <div class="empty-state">
      <p>No jobs match your search. Try a different keyword or check back soon.</p>
    </div>
  <% } else { %>
    <div class="results-bar">
      <p class="results-label">
        Showing <strong><%= jobs.length %></strong> open position<%= jobs.length === 1 ? '' : 's' %><% if (q || location) { %> matching your search<% } %>
      </p>
      <% if (q || location) { %>
        <a class="results-clear" href="/">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
          Clear filters
        </a>
      <% } %>
    </div>

    <% jobs.forEach(function(job) {
      var raw     = job.description.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
      var excerpt = raw.length > 180 ? raw.slice(0, 180).replace(/\s\S*$/, '') + '…' : raw;
      var initials = job.company.trim().replace(/[^a-zA-Z0-9 ]/g,'').split(/\s+/).filter(Boolean).slice(0,2).map(function(w){return w[0].toUpperCase();}).join('') || job.company[0].toUpperCase();
      var colorIdx = job.company.toUpperCase().charCodeAt(0) % 8;
      var daysSince = Math.floor((Date.now() - new Date(job.created_at)) / 86400000);
      var isNew = daysSince <= 3;
      var isRemote = /remote/i.test(job.location);
      var isFeatured = job.featured === 1 && (!job.featured_until || new Date(job.featured_until) > new Date());
    %>
      <div class="job-card <%= isFeatured ? 'is-featured' : '' %>">
        <div class="job-card-inner">
          <div class="job-card-top">
            <!-- Company logo / employer avatar -->
            <% if (job.employer_avatar) { %>
              <img class="job-logo-img" src="/uploads/avatars/<%= job.employer_avatar %>" alt="<%= job.company %>">
            <% } else { %>
              <div class="job-logo logo-c<%= colorIdx %>"><%= initials %></div>
            <% } %>

            <!-- Title + company -->
            <div class="job-card-meta">
              <h3 class="job-card-title">
                <a href="/jobs/<%= job.id %>"><%= job.title %></a>
              </h3>
              <div class="job-company-name"><%= job.company %></div>
            </div>

            <!-- Date + badges -->
            <div class="job-card-date-wrap">
              <div class="job-card-date"><time data-timeago="<%= job.created_at %>"></time></div>
              <% if (isFeatured) { %>
                <div class="featured-badge">★ Featured</div>
              <% } %>
              <% if (job.active === 0) { %>
                <div style="display:inline-block;background:#fee2e2;color:#991b1b;font-size:0.64rem;font-weight:800;letter-spacing:0.07em;text-transform:uppercase;padding:3px 9px;border-radius:20px;margin-top:5px;">Closed</div>
              <% } else if (isNew) { %>
                <div class="new-badge">New</div>
              <% } %>
            </div>
          </div>

          <!-- Pills -->
          <div class="job-pills">
            <span class="job-pill pill-location">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <%= job.location %>
            </span>
            <span class="job-pill pill-type">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.51 15.86 1 13.5 1c-1.28 0-2.44.5-3.3 1.32L9 3.5l-1.2-1.18C6.94 1.5 5.78 1 4.5 1 2.14 1 0 2.51 0 4.64c0 .48.11.92.18 1.36H0v2h20V6zM2.18 6c-.1-.3-.18-.66-.18-1.36C2 3.62 3.12 3 4.5 3c.76 0 1.47.3 2.01.8L8 5.34 9.49 3.8C10.03 3.3 10.74 3 11.5 3c1.36 0 2.5.62 2.5 1.64 0 .7-.08 1.06-.18 1.36H2.18zM2 9v11h7v-5h2v5h7V9H2z"/></svg>
              <%= job.job_type %>
            </span>
            <% if (job.salary) { %>
              <span class="job-pill pill-salary">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
                <%= job.salary %>
              </span>
            <% } %>
            <% if (isRemote) { %>
              <span class="job-pill pill-remote">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor"><path d="M1 9l2 2c4.97-4.97 13.03-4.97 18 0l2-2C16.93 2.93 7.08 2.93 1 9zm8 8l3 3 3-3c-1.65-1.66-4.34-1.66-6 0zm-4-4l2 2c2.76-2.76 7.24-2.76 10 0l2-2C15.14 9.14 8.87 9.14 5 13z"/></svg>
                Remote
              </span>
            <% } %>
          </div>

          <!-- Excerpt -->
          <% if (excerpt) { %>
            <p class="job-excerpt"><%= excerpt %></p>
          <% } %>
        </div>

        <!-- Footer -->
        <div class="job-card-footer">
          <a class="btn-view" href="/jobs/<%= job.id %>">
            View details
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    <% }); %>
  <% } %>
<%- include('../partials/footer') %>
