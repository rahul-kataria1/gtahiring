<%- include('../partials/header') %>
  <style>
    .apply-layout {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 28px;
      align-items: start;
    }
    @media (max-width: 720px) {
      .apply-layout { grid-template-columns: 1fr; }
      .apply-job-summary { order: -1; }
    }

    /* ── Form panel ───────────────────────────────── */
    .apply-panel {
      background: #fff; border: 1px solid var(--border);
      border-radius: 18px; overflow: hidden;
    }
    .apply-panel-header {
      background: linear-gradient(135deg, #001f5b 0%, #0057d8 60%, #4a9af5 100%);
      padding: 24px 28px; color: #fff;
    }
    .apply-panel-header h1 { color: #fff; font-size: 1.4rem; margin: 0 0 4px; }
    .apply-panel-header p  { color: rgba(255,255,255,0.72); margin: 0; font-size: 0.88rem; }
    .apply-panel-body { padding: 28px; }

    /* ── Section heading ──────────────────────────── */
    .form-section-title {
      font-size: 0.78rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.08em; color: var(--muted);
      margin: 24px 0 14px; padding-bottom: 8px;
      border-bottom: 1px solid var(--border-light);
    }
    .form-section-title:first-of-type { margin-top: 0; }

    /* ── Two-col fields row ───────────────────────── */
    .field-row {
      display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
    }
    @media (max-width: 540px) { .field-row { grid-template-columns: 1fr; } }

    /* ── Eligibility radio ────────────────────────── */
    .radio-group { display: flex; gap: 12px; flex-wrap: wrap; }
    .radio-option {
      flex: 1; min-width: 120px;
      display: flex; align-items: center; gap: 10px;
      border: 1.5px solid var(--border); border-radius: 10px;
      padding: 12px 16px; cursor: pointer;
      transition: border-color 0.18s, background 0.18s;
    }
    .radio-option:has(input:checked) {
      border-color: var(--violet); background: var(--violet-bg);
    }
    .radio-option input { accent-color: var(--violet); width: 16px; height: 16px; flex-shrink: 0; }
    .radio-option-label { font-size: 0.9rem; font-weight: 600; color: var(--text); }
    .radio-option-sub   { font-size: 0.76rem; color: var(--muted); }

    /* ── Resume upload ────────────────────────────── */
    .resume-upload-area {
      position: relative; border: 2px dashed var(--violet-light);
      border-radius: 12px; background: var(--violet-bg);
      padding: 32px 24px; text-align: center; cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .resume-upload-area:hover, .resume-upload-area.dragover {
      border-color: var(--violet); background: var(--violet-bg2);
    }
    .resume-upload-area input[type=file] {
      position: absolute; inset: 0; width: 100%; height: 100%;
      opacity: 0; cursor: pointer; z-index: 2;
    }
    .resume-upload-label { display: flex; flex-direction: column; align-items: center; gap: 6px; pointer-events: none; }
    .resume-upload-icon  { font-size: 2.2rem; line-height: 1; }
    .resume-upload-text  { font-size: 0.92rem; color: var(--text); }
    .resume-upload-hint  { font-size: 0.78rem; color: var(--muted); }
    .resume-file-chosen  {
      margin-top: 10px; display: none; align-items: center; gap: 8px;
      background: #fff; border: 1px solid var(--border); border-radius: 8px;
      padding: 7px 13px; font-size: 0.84rem; font-weight: 600;
      color: var(--violet-dark); pointer-events: none; justify-content: center;
    }

    /* ── Job summary card ─────────────────────────── */
    .apply-job-summary {
      background: #fff; border: 1px solid var(--border);
      border-radius: 16px; overflow: hidden;
      position: sticky; top: 80px;
    }
    .apply-job-summary-hero {
      background: linear-gradient(135deg, #001f5b 0%, #0057d8 60%, #4a9af5 100%);
      padding: 20px 20px 16px; color: #fff;
    }
    .apply-job-summary-hero h2 { color: #fff; font-size: 1rem; margin: 0 0 4px; }
    .apply-job-summary-hero p  { color: rgba(255,255,255,0.72); font-size: 0.82rem; margin: 0; }
    .summary-rows { padding: 16px 20px; }
    .summary-row {
      display: flex; align-items: center; gap: 10px;
      padding: 8px 0; border-bottom: 1px solid var(--border-light);
      font-size: 0.85rem;
    }
    .summary-row:last-child { border-bottom: none; }
    .summary-row svg { width: 14px; height: 14px; color: var(--violet); flex-shrink: 0; }
    .summary-row span { color: var(--muted); }
    .summary-row strong { color: var(--text); }
  </style>

  <!-- Breadcrumb -->
  <nav style="display:flex;align-items:center;gap:6px;font-size:0.84rem;margin-bottom:20px;color:var(--muted);">
    <a href="/" style="display:inline-flex;align-items:center;gap:5px;color:var(--violet);font-weight:600;text-decoration:none;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      All jobs
    </a>
    <span style="color:var(--border);">/</span>
    <a href="/jobs/<%= job.id %>" style="color:var(--violet);font-weight:600;text-decoration:none;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;"><%= job.title %></a>
    <span style="color:var(--border);">/</span>
    <span>Apply</span>
  </nav>

  <div class="apply-layout">

    <!-- Main form -->
    <div class="apply-panel">
      <div class="apply-panel-header">
        <h1>Your application</h1>
        <p>Complete the form below and attach your resume to apply for this role.</p>
      </div>
      <div class="apply-panel-body">

        <% if (error) { %>
          <div class="alert error" style="margin-bottom:20px;"><%= error %></div>
        <% } %>

        <form method="POST" action="/jobs/<%= job.id %>/apply" enctype="multipart/form-data">

          <div class="form-section-title">Personal information</div>

          <div class="field-row">
            <div class="field">
              <label for="applicant_name">Full name <span style="color:#ef4444;">*</span></label>
              <input id="applicant_name" name="applicant_name" type="text" required
                value="<%= form.applicant_name !== undefined ? form.applicant_name : seeker.name %>"
                placeholder="Jane Smith">
            </div>
            <div class="field">
              <label for="applicant_email">Email address <span style="color:#ef4444;">*</span></label>
              <input id="applicant_email" name="applicant_email" type="email" required
                value="<%= form.applicant_email !== undefined ? form.applicant_email : seeker.email %>"
                placeholder="jane@example.com">
            </div>
          </div>

          <div class="field">
            <label for="applicant_phone">Phone number <span style="color:#ef4444;">*</span></label>
            <input id="applicant_phone" name="applicant_phone" type="tel" required
              value="<%= form.applicant_phone || seeker.phone || '' %>"
              placeholder="+1 (416) 555-0100">
          </div>

          <div class="form-section-title">Work eligibility</div>

          <div class="field">
            <label>Are you legally eligible to work in Canada? <span style="color:#ef4444;">*</span></label>
            <div class="radio-group" style="margin-top:8px;">
              <label class="radio-option">
                <input type="radio" name="work_eligible" value="yes" required
                  <%= form.work_eligible === 'yes' ? 'checked' : '' %>>
                <div>
                  <div class="radio-option-label">Yes</div>
                  <div class="radio-option-sub">I am authorized to work in Canada</div>
                </div>
              </label>
              <label class="radio-option">
                <input type="radio" name="work_eligible" value="no" required
                  <%= form.work_eligible === 'no' ? 'checked' : '' %>>
                <div>
                  <div class="radio-option-label">No</div>
                  <div class="radio-option-sub">I would require sponsorship</div>
                </div>
              </label>
            </div>
          </div>

          <div class="form-section-title">Resume</div>

          <div class="field">
            <div class="resume-upload-area" id="resume-drop">
              <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx" required>
              <div class="resume-upload-label">
                <span class="resume-upload-icon">📄</span>
                <span class="resume-upload-text">Drag & drop or <strong>browse</strong> to upload</span>
                <span class="resume-upload-hint">PDF, DOC or DOCX &mdash; max 5 MB</span>
              </div>
              <div class="resume-file-chosen" id="resume-chosen"></div>
            </div>
          </div>

          <div style="display:flex;gap:12px;align-items:center;margin-top:8px;">
            <button class="btn" type="submit" style="flex:1;justify-content:center;">Submit application →</button>
            <a href="/jobs/<%= job.id %>" class="btn outline" style="white-space:nowrap;">Cancel</a>
          </div>

        </form>
      </div>
    </div>

    <!-- Job summary sidebar -->
    <aside class="apply-job-summary">
      <div class="apply-job-summary-hero">
        <h2><%= job.title %></h2>
        <p><%= job.company %></p>
      </div>
      <div class="summary-rows">
        <div class="summary-row">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          <span><strong><%= job.location %></strong></span>
        </div>
        <div class="summary-row">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.51 15.86 1 13.5 1c-1.28 0-2.44.5-3.3 1.32L9 3.5 7.8 2.32C6.94 1.5 5.78 1 4.5 1 2.14 1 0 2.51 0 4.64c0 .48.11.92.18 1.36H0v2h20V6zM2 9v11h7v-5h2v5h7V9H2z"/></svg>
          <span><strong><%= job.job_type %></strong></span>
        </div>
        <% if (job.salary) { %>
        <div class="summary-row">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M11.8 10.9c-2.27-.59-3-1.2-3-2.15 0-1.09 1.01-1.85 2.7-1.85 1.78 0 2.44.85 2.5 2.1h2.21c-.07-1.72-1.12-3.3-3.21-3.81V3h-3v2.16c-1.94.42-3.5 1.68-3.5 3.61 0 2.31 1.91 3.46 4.7 4.13 2.5.6 3 1.48 3 2.41 0 .69-.49 1.79-2.7 1.79-2.06 0-2.87-.92-2.98-2.1h-2.2c.12 2.19 1.76 3.42 3.68 3.83V21h3v-2.15c1.95-.37 3.5-1.5 3.5-3.55 0-2.84-2.43-3.81-4.7-4.4z"/></svg>
          <span><strong><%= job.salary %></strong></span>
        </div>
        <% } %>
        <div class="summary-row">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z"/></svg>
          <span>Posted <strong><time data-timeago="<%= job.created_at %>" title="<%= new Date(job.created_at).toLocaleDateString('en-CA', { year:'numeric', month:'short', day:'numeric' }) %>"></time></strong></span>
        </div>
      </div>
    </aside>

  </div>

  <script>
    (function () {
      var input  = document.getElementById('resume');
      var drop   = document.getElementById('resume-drop');
      var chosen = document.getElementById('resume-chosen');
      function showFile(name) {
        chosen.style.display = 'flex';
        chosen.innerHTML = '📄 ' + name;
      }
      input.addEventListener('change', function () { if (input.files[0]) showFile(input.files[0].name); });
      drop.addEventListener('dragover',  function (e) { e.preventDefault(); drop.classList.add('dragover'); });
      drop.addEventListener('dragleave', function ()  { drop.classList.remove('dragover'); });
      drop.addEventListener('drop', function (e) {
        e.preventDefault(); drop.classList.remove('dragover');
        if (e.dataTransfer.files[0]) { input.files = e.dataTransfer.files; showFile(e.dataTransfer.files[0].name); }
      });
    }());
  </script>
<%- include('../partials/footer') %>
