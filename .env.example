PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string

# Used only by db/seed.js to create the first super admin account
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@jobboard.com
ADMIN_PASSWORD=admin123

# ── Email (ZeptoMail API) ────────────────────────────────────────
# Transactional email is sent via Zoho's ZeptoMail HTTPS API rather than
# SMTP, since SMTP ports get blocked/timed out from most cloud hosts.
# Get a Send Mail Token from your ZeptoMail Mail Agent settings.
ZEPTOMAIL_TOKEN=
# Only needed if your ZeptoMail account is on a non-default region.
# ZEPTOMAIL_API_URL=https://api.zeptomail.com/v1.1/email
MAIL_FROM="GTA Hiring <info@gtahiring.com>"

# ── App ───────────────────────────────────────────────────────
APP_URL=https://jobs.gtahiring.com
